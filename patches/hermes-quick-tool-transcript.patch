 _AGENT_WORKING_FRAMES = ("·", "•", "●", "•")
+_FAST_TOOL_TRANSCRIPT_NAMES = frozenset({"todo", "memory", "session_search"})
 
 
 # Load .env from ~/.hermes/.env first, then project root as dev fallback.
@@ -3163,6 +3164,41 @@ class HermesCLI:
