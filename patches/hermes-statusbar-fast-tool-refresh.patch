+    def _get_todo_progress_label(self) -> Optional[str]:
+        agent = getattr(self, "agent", None)
+        store = getattr(agent, "_todo_store", None)
+        if not store or not hasattr(store, "read"):
+            return None
+        try:
+            items = store.read()
+        except Exception:
+            return None
+        if not items:
+            return None
+
+        visible_items = [
+            item
+            for item in items
+            if str(item.get("status", "")).strip().lower() != "cancelled"
+        ]
+        if not visible_items:
+            return None
+
+        completed = sum(
+            1
+            for item in visible_items
+            if str(item.get("status", "")).strip().lower() == "completed"
+        )
+        return f"\u4efb\u52a1\uff1a{completed}/{len(visible_items)}"
+
+    def _update_delegate_subtask_progress(
+        self,
+        task_index: Any = None,
+        task_count: Any = None,
+        *,
+        completed: bool = False,
+    ) -> None:
+        try:
+            total = int(task_count or 0)
+        except (TypeError, ValueError):
+            total = 0
+        try:
+            index = int(task_index) if task_index is not None else None
+        except (TypeError, ValueError):
+            index = None
+        if total <= 0:
+            return
+
+        finished = set(getattr(self, "_delegate_subtask_completed", set()) or set())
+        current_total = int(getattr(self, "_delegate_subtask_total", 0) or 0)
+        if (
+            current_total != total
+            or len(finished) >= current_total > 0
+            or (not completed and index == 0 and finished)
+        ):
+            finished = set()
+
+        if completed and index is not None and index >= 0:
+            finished.add(index)
+
+        self._delegate_subtask_total = total
+        self._delegate_subtask_completed = {
+            item_index for item_index in finished if 0 <= item_index < total
+        }
+
+    def _get_delegate_subtask_label(self) -> Optional[str]:
+        total = int(getattr(self, "_delegate_subtask_total", 0) or 0)
+        if total <= 0:
+            return None
+        completed = min(
+            total,
+            len(getattr(self, "_delegate_subtask_completed", set()) or set()),
+        )
+        return f"\u5b50\u4efb\u52a1\uff1a{completed}/{total}"
+
