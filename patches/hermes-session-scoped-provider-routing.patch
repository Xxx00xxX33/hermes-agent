+    @staticmethod
+    def _get_status_bar_reasoning_label(reasoning_config: Dict[str, Any] | None, *, compact: bool = False) -> tuple[str, str]:
+        abbreviations = {
+            "default": "def",
+            "minimal": "min",
+            "medium": "med",
+            "high": "high",
+            "xhigh": "xhi",
+            "off": "off",
+        }
+        if not reasoning_config:
+            effort = "default"
+            style = "class:status-bar-dim"
+        elif reasoning_config.get("enabled") is False:
+            effort = "off"
+            style = "class:status-bar-dim"
