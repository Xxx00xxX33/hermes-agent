+        if total <= 0:
+            return None
+
+        active_tasks = getattr(self, "_subagent_active_tasks", None)
+        active = 0
+        try:
+            for value in (active_tasks or {}).values():
+                if isinstance(value, (int, float)):
+                    active += max(0, int(value))
+                else:
+                    active += 1
+        except Exception:
+            active = 0
+
+        active = max(0, min(total, active))
+        completed = max(0, total - active)
