+    @staticmethod
+    def _select_status_bar_fallback_todo_item(todo_items: List[Dict[str, str]] | None) -> Dict[str, str] | None:
+        if not todo_items:
+            return None
+
+        for status in ("pending", "completed", "cancelled"):
+            matching = [item for item in todo_items if item.get("status") == status]
+            if not matching:
+                continue
+            if status == "pending":
+                return matching[0]
+            return matching[-1]
+
+        return todo_items[0]
