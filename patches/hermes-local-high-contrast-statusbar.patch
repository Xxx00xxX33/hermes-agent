+
+        separator = " · " if compact else " │ "
+        fragments = []
+        for index, item in enumerate(todo_items):
+            if index:
+                fragments.append(("class:status-bar-dim", separator))
+            content = " ".join(str(item.get("content") or "(no description)").split())
