+
+def test_unlisted_top_level_patch_does_not_count_toward_coverage(tmp_path: Path) -> None:
+    _init_git_repo(tmp_path)
+
+    patches_dir = tmp_path / "patches"
+    patches_dir.mkdir()
+    (tmp_path / "covered.py").write_text("print('covered')\n", encoding="utf-8")
