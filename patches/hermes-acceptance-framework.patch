@@ -0,0 +1,84 @@
+from __future__ import annotations
+
+import importlib.util
+import sys
+from pathlib import Path
+from types import SimpleNamespace
+
+
+SCRIPT_PATH = Path(__file__).resolve().parents[1] / "scripts" / "run_run_agent_acceptance_shards.py"
+
+
+def _load_module():
+    spec = importlib.util.spec_from_file_location("run_run_agent_acceptance_shards", SCRIPT_PATH)
+    module = importlib.util.module_from_spec(spec)
+    assert spec is not None and spec.loader is not None
+    sys.modules[spec.name] = module
+    spec.loader.exec_module(module)
+    return module
+
+
+def test_shards_are_defined_with_expected_sizes():
+    module = _load_module()
+
+    shards = module.get_shards()
+
+    assert set(shards) == {"a", "b", "c"}
+    assert len(shards["a"].tests) == 16
+    assert len(shards["b"].tests) == 18
+    assert len(shards["c"].tests) == 22
+    assert all(arg.startswith("tests/run_agent/test_run_agent.py::TestRunConversation::") for arg in shards["a"].tests)
+
+
+def test_run_shard_invokes_pytest_with_n0(monkeypatch):
+    module = _load_module()
+    calls = []
+
+    def fake_run(cmd, check, cwd=None):
+        calls.append((cmd, check, cwd))
+        return SimpleNamespace(returncode=0)
+
+    monkeypatch.setattr(module.subprocess, "run", fake_run)
+
+    module.run_shards(["b"])
+
+    assert len(calls) == 1
+    cmd, check, cwd = calls[0]
+    assert check is True
+    assert cwd == module.REPO_ROOT
+    assert cmd[:5] == ["uv", "run", "--extra", "dev", "pytest"]
+    assert "-n" in cmd and "0" in cmd
+    assert "-q" in cmd
+    assert any("test_parent_finalizer_runs_executable_command_exit_zero_check" in part for part in cmd)
+
+
+def test_main_list_mode_prints_shard_summary(capsys):
+    module = _load_module()
+
+    exit_code = module.main(["--list"])
+
+    captured = capsys.readouterr()
+    assert exit_code == 0
+    assert "a: 16 tests" in captured.out
+    assert "b: 18 tests" in captured.out
+    assert "c: 22 tests" in captured.out
+
+
+def test_run_shard_executes_from_repo_root(monkeypatch, tmp_path):
+    module = _load_module()
+    calls = []
+
+    def fake_run(cmd, check, cwd=None):
+        calls.append((cmd, check, cwd))
+        return SimpleNamespace(returncode=0)
+
+    monkeypatch.chdir(tmp_path)
+    monkeypatch.setattr(module.subprocess, "run", fake_run)
+
+    module.run_shards(["a"])
+
+    assert len(calls) == 1
+    cmd, check, cwd = calls[0]
+    assert check is True
+    assert cwd == module.REPO_ROOT
+    assert cmd[:5] == ["uv", "run", "--extra", "dev", "pytest"]

diff --git a/docs/acceptance-framework-design.md b/docs/acceptance-framework-design.md
