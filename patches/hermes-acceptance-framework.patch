+import os
+from pathlib import Path
+
+from agent.acceptance import (
+    AcceptanceResult,
+    CheckResult,
+    CriterionEvaluation,
+    CriterionSpec,
+    TaskContract,
+    _build_acceptance_summary,
+    VerificationCheck,
+    _classify_requirement_clauses,
+    _criterion_label,
+    _derive_criterion_metadata,
+    acceptance_result_to_dict,
+    evaluate_claim_evidence_consistency,
+    infer_minimal_task_contract,
+    task_contract_to_dict,
+)
+
+
+def test_task_contract_to_dict_serializes_structured_criteria_and_nested_checks():
+    contract = TaskContract(
+        task_summary="Fix provider label",
+        deliverable="Provider label fixed",
+        success_criteria=["Show named custom provider"],
+        criteria=[
+            CriterionSpec(
+                criterion_id="criterion_1",
+                label="Show named custom provider",
+                evidence_mode="tool_backed",
+            )
+        ],
+        verification_checks=[
+            VerificationCheck(
+                id="tool_evidence",
+                description="Completion claims need tool evidence",
+                kind="tool_evidence",
+                payload={"required_tools": ["read_file"]},
+            )
+        ],
+        inference_quality="high",
+        inference_warnings=["explicit artifact path provided"],
+    )
+
+    data = task_contract_to_dict(contract)
+
+    assert data["task_summary"] == "Fix provider label"
+    assert data["criteria"] == [
+        {
+            "criterion_id": "criterion_1",
+            "label": "Show named custom provider",
+            "evidence_mode": "tool_backed",
+        }
+    ]
+    assert data["inference_quality"] == "high"
+    assert data["inference_warnings"] == ["explicit artifact path provided"]
+    assert data["verification_checks"][0]["id"] == "tool_evidence"
+    assert data["verification_checks"][0]["payload"] == {"required_tools": ["read_file"]}
+
+
+
+def test_acceptance_result_to_dict_serializes_structured_criterion_evaluations_and_check_results():
+    result = AcceptanceResult(
+        status="inconclusive",
+        checks_passed=1,
+        checks_inconclusive=1,
+        unmet_criteria=["startup shows real provider"],
+        missing_evidence=["assistant claimed completion without tool evidence"],
+        passed_criteria=["show named custom provider"],
+        violated_prohibited_actions=[],
+        executable_evidence_checks=["artifact_contains"],
+        failed_checks=[],
+        inconclusive_checks=["tool_evidence"],
+        gate_reason="criterion evidence incomplete",
+        confidence="medium",
+        summary_version=1,
+        criterion_evaluations=[
+            CriterionEvaluation(
+                criterion_id="criterion_1",
+                label="show named custom provider",
+                evidence_mode="tool_backed",
+                status="pass",
+                satisfied_by="tool",
+                evidence=["tool evidence present"],
+                check_id="criterion:criterion_1",
+            )
+        ],
+        check_results=[
+            CheckResult(
+                check_id="tool_evidence",
+                status="inconclusive",
+                evidence=["assistant claimed completion without tool evidence"],
+                details="missing tool messages",
+            )
+        ],
+    )
+
+    data = acceptance_result_to_dict(result)
+
+    assert data["status"] == "inconclusive"
+    assert data["checks_passed"] == 1
+    assert data["passed_criteria"] == ["show named custom provider"]
+    assert data["executable_evidence_checks"] == ["artifact_contains"]
+    assert data["gate_reason"] == "criterion evidence incomplete"
+    assert data["confidence"] == "medium"
+    assert data["summary_version"] == 1
+    assert data["criterion_evaluations"] == [
+        {
+            "criterion_id": "criterion_1",
+            "label": "show named custom provider",
+            "evidence_mode": "tool_backed",
+            "status": "pass",
+            "satisfied_by": "tool",
+            "evidence": ["tool evidence present"],
+            "details": "",
+            "check_id": "criterion:criterion_1",
+        }
+    ]
+    assert data["check_results"][0]["check_id"] == "tool_evidence"
+
+
+
+def test_infer_minimal_task_contract_populates_structured_criteria_metadata():
+    contract = infer_minimal_task_contract("修好 provider label，确保状态栏显示 named custom provider，且输出 status=ok")
+
+    assert [criterion.criterion_id for criterion in contract.criteria] == ["criterion_1", "criterion_2", "criterion_3"]
+    assert [criterion.label for criterion in contract.criteria] == contract.success_criteria
+    assert [criterion.evidence_mode for criterion in contract.criteria] == [
+        "tool_backed",
+        "transcript_ok",
+        "executable_required",
+    ]
+
+
+
+def test_evaluate_claim_evidence_consistency_populates_structured_criterion_evaluations():
+    contract = TaskContract(
+        task_summary="fix provider label",
+        deliverable="provider label fixed",
+        success_criteria=["fix provider label"],
+        criteria=[CriterionSpec(criterion_id="criterion_1", label="fix provider label", evidence_mode="tool_backed")],
+        verification_checks=[
+            VerificationCheck(
+                id="transcript_coverage",
+                description="Final response should cover task",
+                kind="transcript_coverage",
+            ),
+            VerificationCheck(
+                id="tool_evidence",
+                description="Completion claims need tool evidence",
+                kind="tool_evidence",
+            ),
+        ],
+    )
+
+    result = evaluate_claim_evidence_consistency(
+        contract,
+        [
+            {"role": "tool", "tool_name": "read_file", "content": "provider label diff"},
+            {"role": "assistant", "content": "Fixed provider label and verified the change."},
+        ],
+    )
+
+    assert result.criterion_evaluations == [
+        CriterionEvaluation(
+            criterion_id="criterion_1",
+            label="fix provider label",
+            evidence_mode="tool_backed",
+            status="pass",
+            satisfied_by="tool",
+            evidence=["criterion covered: fix provider label"],
+            details="Criterion 1 covered.",
+            check_id="criterion:criterion_1",
+        )
+    ]
+    assert result.check_results[1].check_id == "criterion:criterion_1"
+
+
+
+def test_build_acceptance_summary_prefers_structured_criterion_evaluations():
+    result_json = {
+        "final_assessment": "Acceptance checks passed.",
+        "gate_reason": "all acceptance checks passed",
+        "confidence": "high",
+        "missing_evidence": [],
+        "executable_evidence_checks": ["artifact_contains"],
+        "criterion_evaluations": [
+            {
+                "criterion_id": "criterion_1",
+                "label": "show named custom provider",
+                "evidence_mode": "tool_backed",
+                "status": "pass",
+                "satisfied_by": "tool",
+                "evidence": ["criterion covered: show named custom provider"],
+                "details": "Criterion 1 covered.",
+                "check_id": "criterion:criterion_1",
+            },
+            {
+                "criterion_id": "criterion_2",
+                "label": "startup shows real provider",
+                "evidence_mode": "transcript_ok",
+                "status": "inconclusive",
+                "satisfied_by": "",
+                "evidence": [],
+                "details": "Criterion 2 not clearly covered.",
+                "check_id": "criterion:criterion_2",
+            },
+        ],
+        "check_results": [
+            {"check_id": "transcript_coverage", "status": "inconclusive"},
+            {"check_id": "tool_evidence", "status": "pass"},
+        ],
+    }
+
+    summary = _build_acceptance_summary(result_json)
+
