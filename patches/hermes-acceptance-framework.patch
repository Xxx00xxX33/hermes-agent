+```python
+def infer_task_contract(user_message: str, conversation_history: list[dict[str, Any]] | None = None) -> TaskContract:
+    text = (user_message or "").strip()
+    criteria = []
+    if text:
+        criteria.append(text)
+    # Add split heuristics for common separators / verbs like ensure, verify, fix, implement.
+    # Deduplicate.
+    checks = [
+        VerificationCheck(
+            id="transcript_coverage",
+            description="Final response and transcript should cover the core success criteria.",
+            kind="transcript_coverage",
+            required=True,
+        ),
+        VerificationCheck(
+            id="tool_evidence",
+            description="Key factual completion claims should be backed by tool evidence.",
+            kind="tool_evidence",
+            required=True,
+        ),
+    ]
+    return TaskContract(
+        task_summary=text[:200] or "Current task",
+        deliverable=text[:200] or "Completed result",
+        success_criteria=criteria,
+        verification_checks=checks,
+        completion_mode="advisory",
+        source="agent_inferred",
+    )
+```
