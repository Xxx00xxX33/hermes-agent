+_TRANSCRIPT_ANSI_RE = re.compile(r"\x1b\[[0-?]*[ -/]*[@-~]")
+_TRANSCRIPT_SEPARATOR_CHARS = frozenset("─━═╭╮╰╯┌┐└┘├┤┬┴┼┊│┃┄┈╌╍╎╏ ")
